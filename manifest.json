{
  "manifest_version": 3,
  "name": "Threads Unfollower",
  "version": "1.0.0",
  "description": "Threads'te sizi geri takip etmeyenleri otomatik bulur ve listeler.",
  "author": "kedyflex",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.threads.net/*",
        "*://*.threads.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}